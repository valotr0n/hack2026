# Gateway
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TLS_CERT_FILE=/app/certs/server.crt
TLS_KEY_FILE=/app/certs/server.key
REQUEST_TIMEOUT_SECONDS=120.0

# Auth (JWT)
