# LLM — хакатонный ландшафт (OpenAI-совместимый)
LLM_BASE_URL=https://hackai.centrinvest.ru:6630/v1
LLM_API_KEY=hackaton2026
LLM_MODEL=gpt-oss-20b

# STT — хакатонный ландшафт (Speech-to-Text, аудио → текст)
STT_BASE_URL=https://hackai.centrinvest.ru:6640/v1
STT_API_KEY=hackaton2026
# STT_MODE: api | local | auto (default: auto — API с фолбэком на локальный Whisper)
STT_MODE=auto
# WHISPER_MODEL_SIZE: tiny | base | small | medium (default: small, 244MB)
WHISPER_MODEL_SIZE=small

# TTS — edge-tts (Text-to-Speech, текст → аудио, для подкастов)
TTS_VOICE_ALEX=ru-RU-DmitryNeural
TTS_VOICE_MARIA=ru-RU-SvetlanaNeural

# Закрытый контур — ollama (локальный LLM)
# Переключение: заголовок X-Contour: open | closed
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=qwen2.5:7b
LLM_OPEN_TIMEOUT_SECONDS=180
LLM_OPEN_MAX_CONNECTIONS=200
LLM_OPEN_MAX_KEEPALIVE_CONNECTIONS=50
LLM_CLOSED_TIMEOUT_SECONDS=300
LLM_CLOSED_MAX_CONNECTIONS=64
LLM_CLOSED_MAX_KEEPALIVE_CONNECTIONS=16
CONTENT_SERVICE_WORKERS=4
TIMELINE_MAX_TOKENS=700
CONTRACT_EXTRACT_MAX_TOKENS=1200
CONTRACT_VERIFY_MAX_TOKENS=1200
QUESTIONS_MAX_TOKENS=1000
COMPARE_MAX_TOKENS=1400

# RAG
QDRANT_URL=http://qdrant:6333
AUDIO_DIR=/app/audio
TORCH_NUM_THREADS=28
TORCH_NUM_INTEROP_THREADS=4
EMBEDDING_BATCH_SIZE=128
VISION_ENABLED=true
VISION_MODEL_ID=AvitoTech/avision
# Предзагрузка vision-модели фоном после старта сервиса
VISION_PRELOAD=true
# Ограничение длины ответа vision: меньше токенов -> быстрее описание картинок на CPU
VISION_MAX_NEW_TOKENS=64
# Ограничение размера стороны изображения перед vision-инференсом
VISION_MAX_IMAGE_SIDE=1024

# Gateway *
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TLS_CERT_FILE=/app/certs/server.crt
TLS_KEY_FILE=/app/certs/server.key
REQUEST_TIMEOUT_SECONDS=300.0
CONTRACT_MAX_TEXT_LENGTH=16000
TIMELINE_MAX_TEXT_LENGTH=12000
QUESTIONS_MAX_TEXT_LENGTH=14000
COMPARE_MAX_TEXT_LENGTH=12000
GATEWAY_MAX_CONNECTIONS=200
GATEWAY_MAX_KEEPALIVE_CONNECTIONS=50

# Auth (JWT) + Database
# AUTH_SECRET_KEY — случайная строка, используется для подписи JWT
AUTH_SECRET_KEY=change-me-to-random-string-in-production
DB_PATH=/app/data/platform.db
